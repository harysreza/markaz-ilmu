      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(openssl rand:*)",
      "Bash(grep -l \"from \"\"@/lib/queries\"\"\" src/app/\\\\\\(main\\\\\\)/**/page.tsx)",
